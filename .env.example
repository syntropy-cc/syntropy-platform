# Syntropy Platform — local development (COMP-001.5)
# Copy to .env and fill in values. Never commit .env.

# Database (defaults match docker-compose postgres service)
DATABASE_URL=postgresql://syntropy:syntropy_dev@localhost:5432/syntropy

# Redis
REDIS_URL=redis://localhost:6379

# Kafka
KAFKA_BROKERS=localhost:9092

# Supabase Auth
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# Nostr (artifact anchoring)
NOSTR_RELAY_URLS=

# AI / LLM
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Payments
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# DOI (Labs)
DATACITE_API_KEY=
